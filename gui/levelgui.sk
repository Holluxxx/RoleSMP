##################################################
# GENERIC CHART RENDERER
##################################################
function buildGenericChart(gui: inventory, lvl: number, d1: string, d2: string, d3: string, d4: string, d5: string, d6: string, d7: string, d8: string, d9: string, d10: string, v1: string, v2: string, v3: string, v4: string, v5: string, v6: string, v7: string, v8: string, v9: string, v10: string):

    set {_descs::1} to {_d1}
    set {_descs::2} to {_d2}
    set {_descs::3} to {_d3}
    set {_descs::4} to {_d4}
    set {_descs::5} to {_d5}
    set {_descs::6} to {_d6}
    set {_descs::7} to {_d7}
    set {_descs::8} to {_d8}
    set {_descs::9} to {_d9}
    set {_descs::10} to {_d10}

    set {_vagus::1} to {_v1}
    set {_vagus::2} to {_v2}
    set {_vagus::3} to {_v3}
    set {_vagus::4} to {_v4}
    set {_vagus::5} to {_v5}
    set {_vagus::6} to {_v6}
    set {_vagus::7} to {_v7}
    set {_vagus::8} to {_v8}
    set {_vagus::9} to {_v9}
    set {_vagus::10} to {_v10}

    loop 10 times:
        set {_i} to loop-number
        if {_i} <= 5:
            set {_slot} to 19 + {_i}
        else:
            set {_slot} to 23 + {_i}

        if {_i} <= {_lvl}:
            set slot {_slot} of {_gui} to lime dye named "&a&lLevel %{_i}%" with lore "&7%{_descs::%{_i}%}%" and "" and "&a- UNLOCKED"
        else if {_i} is {_lvl} + 1:
            set slot {_slot} of {_gui} to gold nugget named "&e&lLevel %{_i}% &8(NEXT)" with lore "&7%{_descs::%{_i}%}%" and "" and "&eUse /upgrade to unlock" and "&7Cost: &e%levelCost({_i})% XP Levels"
        else:
            set slot {_slot} of {_gui} to barrier named "&c&lLevel %{_i}% &8[LOCKED]" with lore "&8%{_vagus::%{_i}%}%" and "" and "&cUnlock level %({_i} - 1)% first"

    if {_lvl} >= 10:
        set slot 49 of {_gui} to nether star named "&6&lMAX LEVEL" with lore "&7Your role is fully upgraded!" and "" and "&6You are at peak power."
    else:
        set {_nc} to levelCost({_lvl} + 1)
        set slot 49 of {_gui} to experience bottle named "&eCurrent Progress" with lore "&7Level: &a%{_lvl}%&8/&a10" and "&7Next Level Cost: &e%{_nc}% XP Levels" and "" and "&7Use &a/upgrade &7to advance."

##################################################
# LEVEL GUI -- CLICK HANDLER (view-only)
##################################################
on inventory click:
    if name of event-inventory contains "Level Chart":
        cancel event
        stop
