##################################################
# GUI: LEVEL GUI -- per-role level chart
##################################################

##################################################
# LEVEL GUI BUILDER
##################################################
function openLevelGUI(p: player):
    set {_role} to {role::%uuid of {_p}%}
    set {_lvl} to {roleLevel::%uuid of {_p}%}
    if {_lvl} is not set:
        set {_lvl} to 0

    set {_gui} to chest inventory with 6 rows named "&8Level Chart -- &a%{_role}%"

    loop 54 times:
        set slot (loop-number - 1) of {_gui} to gray stained glass pane named " "

    # Level indicator slots across row 1 (slots 0-9)
    loop 10 times:
        set {_i} to loop-number
        set {_slot} to loop-number - 1
        set {_cost} to levelCost({_i})

        if {_i} <= {_lvl}:
            set slot {_slot} of {_gui} to lime stained glass pane named "&a&lLevel %{_i}% &8[UNLOCKED]" with lore "&7Cost: &e%{_cost}% XP Levels" and "&a- You have this level"
        else if {_i} is {_lvl} + 1:
            set slot {_slot} of {_gui} to yellow stained glass pane named "&e&lLevel %{_i}% &8[NEXT]" with lore "&7Cost: &e%{_cost}% XP Levels" and "&7Use /upgrade to unlock"
        else:
            set slot {_slot} of {_gui} to red stained glass pane named "&c&lLevel %{_i}% &8[LOCKED]" with lore "&7Cost: &e%{_cost}% XP Levels" and "&cUnlock previous levels first"

    # Separator row 2 (slots 9-17)
    loop 9 times:
        set slot (8 + loop-number) of {_gui} to black stained glass pane named " "

    # Role-specific upgrade cards
    if {_role} is "Archer":
        buildArcherChart({_gui}, {_lvl})
    else if {_role} is "Scout":
        buildScoutChart({_gui}, {_lvl})
    else if {_role} is "Miner":
        buildMinerChart({_gui}, {_lvl})
    else if {_role} is "Warrior":
        buildWarriorChart({_gui}, {_lvl})
    else if {_role} is "Farmer":
        buildFarmerChart({_gui}, {_lvl})

    open {_gui} to {_p}

##################################################
# PER-ROLE LEVEL CHARTS + GENERIC RENDERER
##################################################
function buildArcherChart(gui: inventory, lvl: number):
    set {_d1} to "Arrow velocity x1.0, Pierce I, arrows fly further"
    set {_d2} to "Arrow velocity x1.1, Pierce II"
    set {_d3} to "Arrow velocity x1.2, Focus charges faster"
    set {_d4} to "Arrow velocity x1.3, Pierce III"
    set {_d5} to "Arrow velocity x1.45, Focus max mult x3.75"
    set {_d6} to "Arrow velocity x1.6, Infinity on Focus shots"
    set {_d7} to "Arrow velocity x1.8, Pierce IV"
    set {_d8} to "Arrow velocity x2.1, Focus mult x5.0"
    set {_d9} to "Arrow velocity x2.4, Arrows set targets on fire"
    set {_d10} to "MAX: velocity x3.0, Poison on Focus shots, max drop reduction"

    set {_v1} to "??? - Arrows get a bit sharper"
    set {_v2} to "??? - The arrow yearns for speed"
    set {_v3} to "??? - Focus sharpens"
    set {_v4} to "??? - Pierce the impossible"
    set {_v5} to "??? - Power beyond a normal bow"
    set {_v6} to "??? - Legends speak of infinite quivers"
    set {_v7} to "??? - The arrow pierces all"
    set {_v8} to "??? - Focus becomes your best asset"
    set {_v9} to "??? - Your arrows carry the mark of fire"
    set {_v10} to "??? - Ascended Marksman"

    buildGenericChart({_gui}, {_lvl}, {_d1}, {_d2}, {_d3}, {_d4}, {_d5}, {_d6}, {_d7}, {_d8}, {_d9}, {_d10}, {_v1}, {_v2}, {_v3}, {_v4}, {_v5}, {_v6}, {_v7}, {_v8}, {_v9}, {_v10})

